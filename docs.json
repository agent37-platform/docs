  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://www.agent37.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open dashboard",
      "href": "https://www.agent37.com/dashboard/cloud"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "redirects": [
    { "source": "/agents-api/quickstart", "destination": "/" },
    { "source": "/agents-api/messages", "destination": "/agents-api/chat" },
    { "source": "/agents-api/embeds", "destination": "/agents-api/urls" },
    { "source": "/agents-api/scheduled-runs", "destination": "/agents-api/chat" },
    { "source": "/agents-api/integrations", "destination": "/agents-api/budgets" },
    { "source": "/agents-api/skills", "destination": "/agents-api/templates" },
    { "source": "/agents-api/build-your-own-image", "destination": "/agents-api/custom-image" }
