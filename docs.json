{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Agent 37",
  "colors": {
    "primary": "#171717",
    "light": "#8d8d8d",
    "dark": "#000000"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "icon": "globe",
          "href": "https://www.agent37.com"
        },
        {
          "anchor": "Dashboard",
          "icon": "grid-2",
          "href": "https://www.agent37.com/dashboard"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Channels",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          }
        ]
      },
      {
        "tab": "Channels",
        "groups": [
          {
            "group": "Messaging platforms",
            "pages": [
              "channels/introduction",
               "channels/whats-app"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://www.agent37.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open dashboard",
      "href": "https://www.agent37.com/dashboard"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "website": "https://www.agent37.com"
    }
  }
}
