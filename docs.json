        "pages": [
          "agents-api/chat",
          "agents-api/sessions",
          "agents-api/files"
        ]
      },
      {
        "group": "Build with Agent37",
        "pages": [
          "agents-api/white-label",
          "agents-api/chat-app"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "agents-api/streaming",
          "agents-api/billing",
          "agents-api/errors"
        ]
      },
      {
